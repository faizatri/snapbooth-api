APP_NAME=SnapBooth
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=snapbooth
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# local: log | production: pusher
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# ── Storage disk for user uploads (photos, template previews) ─────────────────
# local_public  → stores in storage/app/public/snapbooth (run: php artisan storage:link)
# r2            → uploads to Cloudflare R2 (fill R2_* vars below first)
STORAGE_DISK=local_public

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ── Cloudflare R2 ─────────────────────────────────────────────────────────────
# Obtain these from the Cloudflare dashboard → R2 → Manage API tokens
# R2_ENDPOINT format: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# R2_URL       format: https://your-custom-domain.com  (set in R2 → Public Access)
#              Leave R2_URL empty to use the R2 endpoint URL directly (not recommended)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_DEFAULT_REGION=auto
R2_BUCKET=snapbooth
R2_ENDPOINT=
R2_URL=

# Pusher
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

# Frontend URL (untuk CORS)
FRONTEND_URL=http://localhost:5173

# Share page base URL (dipakai untuk generate link share & QR)
# Production: https://yourdomain.com/share
SHARE_URL=http://localhost:5173/share

VITE_APP_NAME="${APP_NAME}"
